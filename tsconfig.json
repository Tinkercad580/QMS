{
  "compilerOptions": {
    "target": "es2020",
    "module": "Node16",
    "lib": ["es2020", "dom"],
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "noImplicitAny": true,
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "useUnknownInCatchVariables": false,
    "types": ["node"]
  },
  "include": [
    "backend/**/*",
    "tests/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
